{
  "version": 1,
  "name": "csi-pose",
  "expectations": {
    "comparisonType": "live-vs-offline-motion-recording",
    "timestampSource": "sourceMeta.videoTime",
    "interpolate": "offline",
    "offsetMode": "auto",
    "liveTargetStabilization": true,
    "offlineTargetStabilization": false,
    "labelsProvided": true
  },
  "thresholds": {
    "minPairedRatio": 0.95,
    "minOfflineUsageRatio": 0.95,
    "maxTimestampP95Ms": 25,
    "maxTargetP95Deg": 50,
    "maxTargetWeightedP95Deg": 50,
    "maxTargetMaxDeg": 180,
    "maxHingeP95Deg": 55,
    "maxBracketGapP95Ms": 50,
    "maxBracketGapMaxMs": 250,
    "minTargetWeightSum": 1,
    "minFacingAgreement": 0.9,
    "minStableFacingAgreement": 0.6,
    "minYawStateFacingAgreement": 0.78,
    "minYawToleranceFacingAgreement": 0.9,
    "minBackSideFacingAgreement": 0.9,
    "minStableBackSideFacingAgreement": 0.4,
    "minYawBackSideFacingAgreement": 0.7,
    "maxYawP95Deg": 35,
    "minOcclusionCount": 16,
    "maxOcclusionArmP95Deg": 75,
    "maxOcclusionArmMaxDeg": 120,
    "maxPairingDeltaMs": 25,
    "maxEstimatedOffsetAbsMs": 500
  },
  "checks": [
    {
      "metric": "manualLabelsProvided",
      "operator": "===",
      "expected": true,
      "grade": "gate",
      "note": "csi-pose must use user-authored manual labels."
    },
    {
      "metric": "summary.validPairedRatio",
      "operator": ">=",
      "expected": 0.75,
      "grade": "gate",
      "note": "Absent and invalid-reference windows are excluded from pose metrics."
    },
    {
      "metric": "summary.excludedPairs",
      "operator": ">=",
      "expected": 90,
      "grade": "gate",
      "note": "Manual invalid windows must exclude at least the two absent segments."
    },
    {
      "metric": "summary.presenceAgreement.expectedAbsentFrames",
      "operator": ">=",
      "expected": 90,
      "grade": "gate"
    },
    {
      "metric": "summary.gestureAgreement.samVsManualRatio",
      "operator": ">=",
      "expected": 0.35,
      "grade": "gate",
      "note": "Initial SAM-vs-manual gesture agreement gate; later ratchet upward after tracker baselines stabilize."
    },
    {
      "metric": "summary.presenceAgreement.absentSuppressionRatio",
      "operator": ">=",
      "expected": 0.9,
      "grade": "watch",
      "note": "Expected to fail for raw SAM self-reference; tracker runtime should improve this."
    },
    {
      "metric": "byManualFingerMotion.movingToIdleOfflineRatio",
      "operator": ">=",
      "expected": 1.1,
      "grade": "watch",
      "note": "SAM finger motion energy should separate moving from idle after baseline tuning."
    }
  ]
}
